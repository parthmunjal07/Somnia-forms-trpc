{
  "extends": "@repo/typescript-config/node.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "Node",
    "module": "CommonJS",
    // We don't need these for our final build
    "declarationMap": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src"
  ],
  "ts-node": {
    "swc": true
  }
}